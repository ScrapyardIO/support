{
    "name": "scrapyard-io/support",
    "description": "Support Section of The ScrapyardIO Framework",
    "type": "library",
    "version": "0.3.0",
    "keywords": ["framework", "scrapyard-io"],
    "license": "MIT",
    "homepage": "https://dosr.projectsaturnstudios.com",
    "authors": [
        {
            "name": "Angel Gonzalez",
            "email": "angel@projectsaturnstudios.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "ScrapyardIO\\Support\\": "src/"
        },
        "files": [
            "src/Helpers/support.php",
            "src/Helpers/bytes.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "DeptOfScrapyardRobotics\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
